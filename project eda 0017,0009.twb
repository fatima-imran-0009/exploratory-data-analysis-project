      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_1257316093411328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='AOV' datatype='real' default-format='p0.00%' name='[Calculation_1257316094447617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order ID])' />
      </column>
      <column caption='Total Discount Value' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;(&quot;$&quot;#,##0,.00K)' name='[Calculation_1257316094648322]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales] * [Discount])' />
      </column>
      <column caption='return rate' datatype='real' default-format='p0.00%' name='[Calculation_1257316104261637]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Returned] = &apos;Yes&apos; THEN [Order ID] END) / COUNTD([Order ID])' />
      </column>
      <column caption='Pareto Sales' datatype='real' name='[Calculation_1257316115292170]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales])) / TOTAL(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Unique Customers' datatype='integer' name='[Calculation_1257316126928907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer ID])' />
      </column>
      <column caption=' Days to Ship' datatype='integer' name='[Calculation_1257316142137356]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Order Date], [Ship Date])' />
      </column>
      <column caption='Delayed Orders' datatype='integer' datatype-customized='true' name='[Calculation_1257316149424144]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT(IF [Calculation_1257316142137356] &gt; 5 THEN &quot;Delayed&quot; ELSE &quot;On Time&quot; END)' />
      </column>
